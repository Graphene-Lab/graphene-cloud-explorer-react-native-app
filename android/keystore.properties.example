# ============================================================
# Release Signing — TEMPLATE  (safe to commit)
# ============================================================
# Copy this file to android/keystore.properties and fill in
# the real values. That file is gitignored and stays local
# to this project only — no conflicts with other projects.
#
# Put your .keystore file anywhere inside android/app/ —
# it is automatically excluded by *.keystore in .gitignore.
# ============================================================

# Path to the keystore, relative to the android/ directory
APP_UPLOAD_STORE_FILE=app/graphenelab-upload.keystore

# Keystore password (set when you ran keytool -genkeypair)
APP_UPLOAD_STORE_PASSWORD=your_store_password_here

# Alias of the signing key inside the keystore
APP_UPLOAD_KEY_ALIAS=graphenelab-upload

# Key password (can be the same as the store password)
APP_UPLOAD_KEY_PASSWORD=your_key_password_here